{
  "name": "nmtb",
  "main": "./.webpack/main",
  "homepage": "/nmtb",
  "version": "1.0.0",
  "description": "NMTB Application",
  "author": "HIMS",
  "license": "MIT",
  "scripts": {
    "start": "powershell clear && react-scripts start",
    "build": "set \"GENERATE_SOURCEMAP=false\" && react-scripts build && npm run copyAsset && npm run copyFontAssets",
    "copyAsset": "cmd /c xcopy /E /I /Y \"./webapp-options\" \"./build\"",
    "copyFontAssets": "cmd /c if not exist \".\\build\\webfonts\" mkdir \".\\build\\webfonts\" && xcopy /Y /I \".\\node_modules\\@fortawesome\\fontawesome-free\\webfonts\\*\" \".\\build\\webfonts\\\"",
    "test": "react-scripts test",
    "electron": "electron .",
    "electron-start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-free": "6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@reduxjs/toolkit": "^2.1.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.69",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "axios": "^1.6.3",
    "bootstrap": "^5.3.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-squirrel-startup": "^1.0.0",
    "react": "^18.2.0",
    "react-bootstrap": "^2.9.0",
    "react-bootstrap-icons": "^1.11.6",
    "react-bootstrap-typeahead": "^6.3.2",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-idle-timer": "^5.7.2",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.21.1",
    "react-scripts": "^5.0.1",
    "react-to-print": "^2.15.1",
    "react-toastify": "^10.0.3",
    "recharts": "^3.2.1",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^3.1.0",
    "sweetalert2": "^11.26.3",
    "typescript": "^4.9.5",
    "wait-on": "^7.2.0",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "@electron-forge/maker-rpm": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.2.0",
    "@electron-forge/plugin-webpack": "^7.2.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "electron": "^28.2.1",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "ts-loader": "^9.5.1",
    "webpack-cli": "^5.1.4"
  }
}
